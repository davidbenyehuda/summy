{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Python Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "server.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "3001"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "jinja": true,
      "justMyCode": true
    },
    {
      "name": "Debug Python Backend (reload)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "server.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "3001",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "jinja": true,
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "Vite Frontend",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:client"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Debug Full Stack",
      "configurations": [
        "Debug Python Backend (reload)",
        "Vite Frontend"
      ],
      "stopAll": true
    }
  ]
}
